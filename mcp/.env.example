# Rename to .env and fill in. The MCP server refuses to start if any of these are missing.

# Shared secret. Required by the MCP server at startup. If you later add an API Gateway
# authorizer, the server sends this as the X-API-Key header on every Lambda call.
MCP_API_KEY=replace-me-with-a-long-random-string

# The deployed API Gateway base URL (no trailing slash). Get this from the
# `ApiURL` output in serverless.template after `sam deploy`.
LAMBDA_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/Prod

# Numeric website ID this MCP instance manages. Each MCP server is scoped to one site.
WEBSITE_ID=1
